{
  "name": "raio-x-do-governo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nx dev web",
    "build": "nx build web",
    "start": "nx start web",
    "lint": "nx lint web",
    "test": "vitest --config apps/web/vitest.config.ts",
    "test:run": "vitest run --config apps/web/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config apps/web/vitest.config.ts",
    "sonar:up": "docker compose -f docker-compose.sonar.yml up -d",
    "sonar:down": "docker compose -f docker-compose.sonar.yml down",
    "sonar:clean": "docker compose -f docker-compose.sonar.yml down -v",
    "sonar:scan": "export $(cat .env.sonar | xargs) && docker run --rm --network sonar-net -e SONAR_TOKEN -v \"$(pwd):/usr/src\" sonarsource/sonar-scanner-cli -Dsonar.token=$SONAR_TOKEN",
    "sonar:check": "npm run test:coverage && npm run sonar:scan"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/client": "^7.5.0",
    "@tanstack/react-query": "^5.91.2",
    "@upstash/redis": "^1.37.0",
    "framer-motion": "^12.38.0",
    "next": "16.2.0",
    "nuqs": "^2.8.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.17",
    "@nx/next": "22.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "jsdom": "^29.0.0",
    "nx": "22.6.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "nx": {}
}
