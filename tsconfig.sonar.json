{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./apps/web/src/*"],
      "@raio-x/types": ["./libs/shared/types/src/index.ts"],
      "@raio-x/utils": ["./libs/shared/utils/src/index.ts"]
    }
  },
  "include": [
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/api/src/**/*.ts",
    "libs/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".next"]
}
