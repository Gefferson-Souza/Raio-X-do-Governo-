generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model SyncJob {
  id             String    @id @default(uuid())
  jobType        String
  status         String    @default("running")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMs     Int?
  recordsFetched Int       @default(0)
  recordsFailed  Int       @default(0)
  errorMessage   String?
  metadata       Json?

  rawResponses         RawResponse[]
  politiciansSnapshots PoliticiansSnapshot[]
  spendingSnapshots    SpendingSnapshot[]
  contractSnapshots    ContractSnapshot[]

  @@index([jobType, status])
  @@index([startedAt])
  @@map("sync_jobs")
}

model RawResponse {
  id                String   @id @default(uuid())
  source            String
  endpointUrl       String
  httpMethod        String   @default("GET")
  httpStatus        Int
  responseHash      String
  responseBody      Json
  responseSizeBytes Int
  fetchedAt         DateTime @default(now())
  durationMs        Int
  syncJobId         String?
  syncJob           SyncJob? @relation(fields: [syncJobId], references: [id])

  @@index([source, fetchedAt])
  @@index([syncJobId])
  @@index([responseHash])
  @@map("raw_responses")
}

model PoliticiansSnapshot {
  id        String   @id @default(uuid())
  version   Int
  periodo   Json
  deputados Json
  senadores Json
  emendas   Json
  viagens   Json
  cartoes   Json
  status    String   @default("ok")
  syncJobId String
  syncJob   SyncJob  @relation(fields: [syncJobId], references: [id])
  createdAt DateTime @default(now())
  isLatest  Boolean  @default(true)

  @@index([isLatest])
  @@index([syncJobId])
  @@map("politicians_snapshots")
}

model SpendingSnapshot {
  id             String   @id @default(uuid())
  version        Int
  ano            Int
  totalPago      Decimal  @db.Decimal(18, 2)
  totalEmpenhado Decimal  @db.Decimal(18, 2)
  totalLiquidado Decimal  @db.Decimal(18, 2)
  porOrgao       Json
  syncJobId      String
  syncJob        SyncJob  @relation(fields: [syncJobId], references: [id])
  createdAt      DateTime @default(now())
  isLatest       Boolean  @default(true)

  @@index([ano, isLatest])
  @@map("spending_snapshots")
}

model ContractSnapshot {
  id            String   @id @default(uuid())
  version       Int
  contratos     Json
  periodoInicio DateTime
  periodoFim    DateTime
  syncJobId     String
  syncJob       SyncJob  @relation(fields: [syncJobId], references: [id])
  createdAt     DateTime @default(now())
  isLatest      Boolean  @default(true)

  @@index([isLatest])
  @@map("contract_snapshots")
}

model DisplaySnapshot {
  id             String    @id @default(uuid())
  pageRoute      String
  componentName  String
  dataType       String
  dataSnapshotId String
  servedAt       DateTime  @default(now())
  invalidatedAt  DateTime?

  @@index([pageRoute, servedAt])
  @@index([dataType, dataSnapshotId])
  @@map("display_snapshots")
}
